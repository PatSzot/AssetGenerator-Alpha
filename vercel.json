{
  "functions": {
    "api/certificate.js": {
      "memory": 1024,
      "maxDuration": 45,
      "runtime": "nodejs18.x"
    },
    "api/stipple.js": {
      "maxDuration": 60
    },
    "api/render.js": {
      "memory": 1024,
      "maxDuration": 60,
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
